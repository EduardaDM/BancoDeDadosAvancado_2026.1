drop trigger tg_inserindo_pessoa;
delimiter $
create trigger tg_alterando_pessoa
after insert on pessoa for each row 
begin 
if old.nome <> new.nome then
	insert into registro_log(dt_op,hr_,ds_op)
		values (curdate(),curtime(),concat('Alterando row pessoa id: 
		 para: ',new.nome));
end $
